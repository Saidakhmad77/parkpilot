<mujoco model="parkpilot_parking">
  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.01" iterations="50" solver="Newton"/>

  <default>
    <geom condim="3" friction="1.0 0.005 0.0001"/>
  </default>

  <statistic center="1.0 0.0 0.0" extent="3.0"/>

  <worldbody>
    <light name="key_light" directional="true" pos="1 -2 4" dir="-0.2 0.4 -1"/>
    <camera name="overview" pos="1.1 -2.7 2.6" xyaxes="1 0 0 0 0.693 0.720"/>

    <geom name="floor" type="plane" size="4 3 0.1" rgba="0.35 0.45 0.38 1"/>
    <geom name="ground_slab" type="box" pos="2.0 0.0 0.00025"
          size="1.0 0.75 0.00025" rgba="0.25 0.30 0.28 1"
          contype="0" conaffinity="0"/>

    <site name="target_slot" type="box" pos="2.0 0.0 0.001"
          size="0.30 0.16 0.001" rgba="0.9 0.8 0.1 0.7"/>

    <geom name="left_parked_car" type="box" pos="2.0 0.55 0.06"
          size="0.30 0.14 0.06" rgba="0.7 0.2 0.2 1"/>
    <geom name="right_parked_car" type="box" pos="2.0 -0.55 0.06"
          size="0.30 0.14 0.06" rgba="0.2 0.5 0.7 1"/>

    <body name="car" pos="0 0 0.06">
      <joint name="car_x" type="slide" axis="1 0 0"/>
      <joint name="car_y" type="slide" axis="0 1 0"/>
      <joint name="car_z_rot" type="hinge" axis="0 0 1"/>

      <geom name="car_chassis" type="box" size="0.25 0.12 0.06" rgba="0.1 0.25 0.9 1"/>
      <geom name="front_marker" type="box" pos="0.28 0 0.02"
            size="0.03 0.08 0.04" rgba="1.0 0.45 0.05 1"/>
    </body>
  </worldbody>

  <actuator>
    <velocity name="drive" joint="car_x" kv="1" ctrlrange="-2 2" ctrllimited="true"/>
    <position name="steer" joint="car_z_rot" kp="5" ctrlrange="-0.6 0.6" ctrllimited="true"/>
  </actuator>
</mujoco>
